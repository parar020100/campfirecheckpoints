# Игнорируем файлы IDE
/.idea/
/.vscode/
*.iml
*.ipr
*.iws

# Игнорируем сгенерированные файлы Maven
/target/
/logs/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties

# Игнорируем временные файлы
*.tmp
*.bak
*.swp
*~.nib
*.orig

# Игнорируем системные файлы
.DS_Store
Thumbs.db

# Игнорируем локальные настройки
/settings/
*.prefs

# Игнорируем билды плагина (кроме финального jar)
!target/*.jar
target/*.jar.*

# Игнорируем кэш Maven (не нужно коммитить)
/.mvn/
mvnw
mvnw.cmd

# Игнорируем тестовые серверные файлы
/server/
/run/
/plugins/
/world*/
/logs/
*.log